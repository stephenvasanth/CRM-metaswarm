# Copy this file to .env and fill in your values
# NEVER commit .env — it is in .gitignore
#
# metaswarm projects use .env for secrets and configuration.
# Document all required and optional env vars here.

# Add your environment variables below:

# ---------------------------------------------------------------------------
# Database (PostgreSQL 16)
# ---------------------------------------------------------------------------
POSTGRES_DB=crm
POSTGRES_USER=crm
# WARNING: change this in production — this is a dev-only default
POSTGRES_PASSWORD=crm_secret

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# REQUIRED — must be at least 32 characters for HS256. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# ---------------------------------------------------------------------------
# CORS / Origins
# ---------------------------------------------------------------------------
# Origin allowed by the backend CORS policy (no trailing slash)
FRONTEND_ORIGIN=http://localhost:4200

# ---------------------------------------------------------------------------
# Internal service URLs (used by nginx inside the crm-ui container)
# ---------------------------------------------------------------------------
# Backend base URL as seen from inside the Docker network
API_URL=http://crm-service:8080
